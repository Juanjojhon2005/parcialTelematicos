zone "empresa.local" {
    type master;
    file "/etc/bind/db.empresa.local";
    allow-transfer { 192.168.56.11; };
};

zone "56.168.192.in-addr.arpa" {
    type master;
    file "/etc/bind/db.192";
};

zone "juanjosesantacruz.com" {
    type master;
    file "/etc/bind/db.juanjosesantacruz";
    allow-transfer { 192.168.56.11; };
};
