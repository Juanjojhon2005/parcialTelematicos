options {
    directory "/var/cache/bind";

    recursion no;                     // Dejo no resolver
    allow-query { any; };              // Puede responder zona autoritativa
    allow-transfer { 192.168.56.11; }; // Solo el esclavo puede 

    notify yes;

    dnssec-validation no;

    listen-on { any; };
    listen-on-v6 { any; };
};
